{
  "name": "react-production-boilerplate",
  "version": "1.0.0",
  "description": "A modern, scalable, and enterprise-ready React application template built from scratch. \r This boilerplate avoids the black-box abstraction of Create React App (CRA) and provides full control over the build process, developer experience, and deployment pipeline.",
  "homepage": "https://github.com/VladislavShipovskoi/react-production-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/VladislavShipovskoi/react-production-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VladislavShipovskoi/react-production-boilerplate.git"
  },
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "webpack --mode production",
    "lint:code": "eslint src --ext .ts,.tsx --fix",
    "lint:style": "stylelint \"src/**/*.scss\" --fix",
    "lint": "npm run lint:code && npm run lint:style",
    "test": "jest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "babel-loader": "^10.1.1",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0"
  }
}
